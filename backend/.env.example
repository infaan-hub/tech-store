SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,.onrender.com,.vercel.app
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Email settings for order and payment notifications
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your_google_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=yourgmail@gmail.com

# Google customer login
GOOGLE_CLIENT_ID=your_google_oauth_client_id
